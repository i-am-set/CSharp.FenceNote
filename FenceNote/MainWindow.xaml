<Window x:Class="FenceNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FenceNote.ViewModels"
        xmlns:mvvm="clr-namespace:FenceNote.MVVM"
        mc:Ignorable="d"
        Title="FenceNote" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="WindowBgBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="Pane1BgBrush" Color="#DCDCDC" />
        <SolidColorBrush x:Key="Pane2BgBrush" Color="#EAEAEA" />
        <SolidColorBrush x:Key="Pane3BgBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#000000" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888" />
        <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="TextCaretBrush" Color="#000000" />
        <SolidColorBrush x:Key="HighlightBrush" Color="#0078D7" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding AddNoteCommand}" />
        <KeyBinding Key="V" Modifiers="Ctrl+Shift" Command="{Binding RequestCreateVaultCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding RequestDeleteNoteCommand}" />
    </Window.InputBindings>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Vaults Pane -->
            <Grid Grid.Column="0" Background="{DynamicResource Pane1BgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" 
                        Content="PUBLIC NOTES" 
                        Command="{Binding ClearVaultSelectionCommand}" 
                        Margin="10,10,10,5" 
                        Padding="10" 
                        MinHeight="40"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource Pane2BgBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource HighlightBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPublicNotesSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HighlightBrush}" />
                                    <Setter Property="Foreground" Value="#EAEAEA" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                        <Condition Binding="{Binding IsPublicNotesSelected}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="#15888888" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Grid.Row="1" 
                           Text="VAULTS" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Margin="15,10,10,5" />

                <ItemsControl Grid.Row="2" 
                              ItemsSource="{Binding Vaults}" 
                              Margin="5,0,5,0">
                    <ItemsControl.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add New Vault" Command="{Binding RequestCreateVaultCommand}" />
                        </ContextMenu>
                    </ItemsControl.ContextMenu>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectVaultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="0"
                                    Cursor="Hand">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Lock Vault" 
                                                  Command="{Binding PlacementTarget.Tag.LockVaultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="{Binding LockoutDisplay, StringFormat='Lockout Timer ({0})'}">
                                            <MenuItem Header="15 seconds" Command="{Binding PlacementTarget.Tag.SetLockout15sCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="30 seconds" Command="{Binding PlacementTarget.Tag.SetLockout30sCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="1 minute" Command="{Binding PlacementTarget.Tag.SetLockout1mCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="5 minutes" Command="{Binding PlacementTarget.Tag.SetLockout5mCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="15 minutes" Command="{Binding PlacementTarget.Tag.SetLockout15mCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Rename" 
                                                  Command="{Binding PlacementTarget.Tag.BeginRenameVaultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Delete" 
                                                  Command="{Binding PlacementTarget.Tag.DeleteVaultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Pane2BgBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource HighlightBrush}" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#15888888" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUnlockTarget}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#15888888" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Margin="10,0,5,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#D13438" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsUnlockTarget}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="0" Text="&#xE785;" FontFamily="Segoe MDL2 Assets" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="10,0,5,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                               Padding="5,10,10,10" 
                                               TextTrimming="CharacterEllipsis" 
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                             Padding="6,8"
                                             Margin="2"
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource Pane3BgBrush}"
                                             BorderThickness="1"
                                             BorderBrush="#0078D7"
                                             CaretBrush="{DynamicResource TextCaretBrush}"
                                             LostFocus="RenameTextBox_LostFocus"
                                             KeyDown="RenameTextBox_KeyDown"
                                             mvvm:FocusExtension.IsFocused="{Binding IsEditing}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Column="2" Text="{Binding RemainingLockoutDisplay}" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" 
                                               FontSize="10" 
                                               VerticalAlignment="Center" 
                                               Margin="5,0,10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Row="3" 
                        Content="+ New Vault" 
                        Command="{Binding RequestCreateVaultCommand}" 
                        ToolTip="New Vault (Ctrl+Shift+V)"
                        Margin="10,5,10,15" 
                        Padding="5" 
                        Background="#0078D7" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>

            <!-- Notes List Pane -->
            <Grid Grid.Column="1" Background="{DynamicResource Pane2BgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="{Binding NotesPaneTitle}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Margin="15,20,10,5" />

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding DisplayedNotes}" 
                         SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                         Background="Transparent" 
                         BorderThickness="0" 
                         Margin="5,0,5,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add New Note" Command="{Binding AddNoteCommand}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Move to Vault" 
                                                  Command="{Binding PlacementTarget.Tag.RequestMoveToVaultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VaultId}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>
                                        <MenuItem Header="Rename" 
                                                  Command="{Binding PlacementTarget.Tag.BeginRenameNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Delete" 
                                                  Command="{Binding PlacementTarget.Tag.RequestDeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Title}" 
                                           Padding="10" 
                                           TextTrimming="CharacterEllipsis" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=Explicit}" 
                                         Padding="6,8"
                                         Margin="2"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Background="{DynamicResource Pane3BgBrush}"
                                         BorderThickness="1"
                                         BorderBrush="#0078D7"
                                         CaretBrush="{DynamicResource TextCaretBrush}"
                                         LostFocus="RenameTextBox_LostFocus"
                                         KeyDown="RenameTextBox_KeyDown"
                                         mvvm:FocusExtension.IsFocused="{Binding IsEditing}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" 
                        Content="+ New Note" 
                        Command="{Binding AddNoteCommand}" 
                        ToolTip="New Note (Ctrl+T)"
                        Margin="10,5,10,15" 
                        Padding="5" 
                        Background="#0078D7" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>

            <!-- Editor Pane -->
            <Grid Grid.Column="2" Background="{DynamicResource Pane3BgBrush}" IsEnabled="{Binding IsNoteSelected}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" 
                         Text="{Binding SelectedNote.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="24" 
                         FontWeight="Bold" 
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextCaretBrush}"
                         BorderThickness="0" 
                         Margin="20,20,20,10" 
                         Background="Transparent" />

                <TextBox Grid.Row="1" 
                         Text="{Binding SelectedNote.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextCaretBrush}"
                         BorderThickness="0" 
                         Margin="20,0,20,10" 
                         FontSize="14" 
                         Background="Transparent" 
                         VerticalScrollBarVisibility="Auto" />

                <Grid Grid.Row="2" Margin="20,0,20,20" Visibility="{Binding IsNoteSelected, Converter={StaticResource BoolToVis}}">
                    <Button Content="DELETE NOTE" 
                            HorizontalAlignment="Center"
                            Command="{Binding RequestDeleteNoteCommand}" 
                            ToolTip="Delete Note (Ctrl+W)"
                            Padding="15,5" 
                            Background="#D13438" 
                            Foreground="White" 
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="1" Background="{DynamicResource Pane1BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                <Button Content="Toggle Dark Mode" 
                        Command="{Binding ToggleDarkModeCommand}" 
                        Padding="15,0" 
                        Background="Transparent" 
                        Foreground="{DynamicResource TextPrimaryBrush}" 
                        BorderThickness="1,0,1,0" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        Cursor="Hand" 
                        VerticalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Popups and Notifications (Z-Index Top) -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="100" IsHitTestVisible="False">

            <!-- Stacking Notifications -->
            <ItemsControl ItemsSource="{Binding Notifications}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#4CAF50" CornerRadius="4" Padding="15,10" Margin="0,0,0,10">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="True" RenderAtScale="1" />
                            </Border.CacheMode>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2" />
                            </Border.Effect>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
                                            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,-20,0,10" To="0,0,0,10" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <TextBlock Text="{Binding Message}" Foreground="White" FontWeight="SemiBold" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Delete Note Prompt -->
        <Popup IsOpen="{Binding IsDeletePromptOpen, Mode=TwoWay}" 
               Placement="Center" 
               StaysOpen="False" 
               AllowsTransparency="True">
            <Border Background="{DynamicResource Pane3BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" CornerRadius="4" Width="300">
                <Border.CacheMode>
                    <BitmapCache EnableClearType="True" RenderAtScale="1" />
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Are you sure you want to delete this note?" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold" 
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="CANCEL" 
                                Command="{Binding CancelDeleteNoteCommand}" 
                                Margin="0,0,10,0" 
                                Padding="15,5" 
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Background="{DynamicResource Pane2BgBrush}" 
                                BorderThickness="0" 
                                Cursor="Hand"/>
                        <Button Content="DELETE" 
                                Command="{Binding ConfirmDeleteNoteCommand}" 
                                Padding="15,5" 
                                Background="#D13438" 
                                Foreground="White" 
                                BorderThickness="0" 
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Create Vault Prompt -->
        <Popup IsOpen="{Binding IsVaultPromptOpen, Mode=TwoWay}" 
               Placement="Center" 
               StaysOpen="False" 
               AllowsTransparency="True">
            <Border Background="{DynamicResource Pane3BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" CornerRadius="4" Width="350">
                <Border.CacheMode>
                    <BitmapCache EnableClearType="True" RenderAtScale="1" />
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Create New Vault" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,15" />

                    <TextBlock Text="Vault Name" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <TextBox Text="{Binding VaultNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5" Background="{DynamicResource Pane2BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" />

                    <TextBlock Text="Vault Password" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <PasswordBox x:Name="VaultPasswordBox" PasswordChanged="VaultPasswordBox_PasswordChanged" Margin="0,0,0,15" Padding="5" Background="{DynamicResource Pane2BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" />

                    <TextBlock Text="Confirm Password" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <PasswordBox x:Name="VaultConfirmPasswordBox" PasswordChanged="VaultConfirmPasswordBox_PasswordChanged" Margin="0,0,0,15" Padding="5" Background="{DynamicResource Pane2BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" />

                    <TextBlock Text="WARNING: If you forget this password, your data cannot be recovered." Foreground="#D13438" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,20" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelCreateVaultCommand}" Margin="0,0,10,0" Padding="15,5" Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource Pane2BgBrush}" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Create Vault" Command="{Binding ConfirmCreateVaultCommand}" Padding="15,5" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Unlock Vault Prompt -->
        <Popup IsOpen="{Binding IsUnlockPromptOpen, Mode=TwoWay}" 
               Placement="Center" 
               StaysOpen="False" 
               AllowsTransparency="True">
            <Border Background="{DynamicResource Pane3BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" CornerRadius="4" Width="300">
                <Border.CacheMode>
                    <BitmapCache EnableClearType="True" RenderAtScale="1" />
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding UnlockPromptTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,15" />

                    <TextBlock Text="Enter Vault Password" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <PasswordBox x:Name="UnlockVaultPasswordBox" PasswordChanged="UnlockVaultPasswordBox_PasswordChanged" KeyDown="UnlockVaultPasswordBox_KeyDown" Margin="0,0,0,20" Padding="5" Background="{DynamicResource Pane2BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelUnlockVaultCommand}" Margin="0,0,10,0" Padding="15,5" Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource Pane2BgBrush}" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Unlock" Command="{Binding ConfirmUnlockVaultCommand}" Padding="15,5" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Move to Vault Prompt -->
        <Popup IsOpen="{Binding IsMoveToVaultPromptOpen, Mode=TwoWay}" 
               Placement="Center" 
               StaysOpen="False" 
               AllowsTransparency="True">
            <Border Background="{DynamicResource Pane3BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" CornerRadius="4" Width="300">
                <Border.CacheMode>
                    <BitmapCache EnableClearType="True" RenderAtScale="1" />
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Move to Vault" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,15" />

                    <ItemsControl ItemsSource="{Binding Vaults}" 
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  MaxHeight="200"
                                  Margin="0,0,0,15">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" 
                                        Command="{Binding DataContext.ConfirmMoveToVaultCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Pane1BgBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ New Vault" 
                            Command="{Binding RequestCreateVaultCommand}" 
                            Margin="0,0,0,15" 
                            Padding="10,5" 
                            Background="#0078D7" 
                            Foreground="White" 
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelMoveToVaultCommand}" Padding="15,5" Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource Pane2BgBrush}" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>